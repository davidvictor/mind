# AI Gateway API — required for routed LLM execution
AI_GATEWAY_API_KEY=

# Gemini API — only needed when you intentionally bypass the gateway
GEMINI_API_KEY=

# OpenAI API — only needed when you intentionally bypass the gateway
OPENAI_API_KEY=

# Anthropic API — only needed when you intentionally bypass the gateway
ANTHROPIC_API_KEY=

# Which browser to extract YouTube cookies from
# Options: chrome, comet, safari, firefox, brave, edge, chromium
BROWSER_FOR_COOKIES=chrome

# Private local data wiring. Leave blank to use local_data/ defaults from
# config.example.yaml or set absolute paths in your private local config.
BRAIN_CONFIG_PATH=
BRAIN_LOCAL_DATA_ROOT=local_data
BRAIN_MEMORY_ROOT=
BRAIN_RAW_ROOT=
BRAIN_DROPBOX_ROOT=
BRAIN_STATE_ROOT=
